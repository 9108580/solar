# Copy to .env.local for local dev (never commit .env.local)
# In Vercel: Project → Settings → Environment Variables (same names)

REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_public_key

# Same values as production → local `npm start` loads prices/agents from Supabase automatically.
# Optional backup file: npm run pull:admin → admin-settings-from-cloud.json (gitignored)
